<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.UserPlayRecordMapper">
    
    <resultMap type="UserPlayRecord" id="UserPlayRecordResult">
        <result property="id"    column="id"    />
        <result property="videoId"    column="video_id"    />
        <result property="userId"    column="user_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="videoTitle"    column="video_title"    />
        <result property="videoImg"    column="video_img"    />
    </resultMap>

    <sql id="selectUserPlayRecordVo">
        select id, video_id, user_id, create_by, create_time, update_by, update_time from v_user_play_record
    </sql>

    <select id="selectUserPlayRecordList" parameterType="UserPlayRecord" resultMap="UserPlayRecordResult">
        select v.id, v.video_id, v.user_id, v.create_by, v.create_time, v.update_by, v.update_time,
        vi.title as videoTitle, vi.img as videoImg
        from v_user_play_record v left join v_video vi on vi.id = v.video_id
        <where>  
            <if test="userId != null "> and v.user_id = #{userId}</if>
        </where>
    </select>
    
    <select id="selectUserPlayRecordById" parameterType="Long" resultMap="UserPlayRecordResult">
        <include refid="selectUserPlayRecordVo"/>
        where id = #{id}
    </select>

    <insert id="insertUserPlayRecord" parameterType="UserPlayRecord" useGeneratedKeys="true" keyProperty="id">
        insert into v_user_play_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="videoId != null">video_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="videoId != null">#{videoId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateUserPlayRecord" parameterType="UserPlayRecord">
        update v_user_play_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="videoId != null">video_id = #{videoId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteUserPlayRecordById" parameterType="Long">
        delete from v_user_play_record where id = #{id}
    </delete>

    <delete id="deleteUserPlayRecordByIds" parameterType="String">
        delete from v_user_play_record where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>