<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AdRegRecordMapper">

    <resultMap type="AdRegRecord" id="AdRegRecordResult">
        <result property="id" column="id"/>
        <result property="adId" column="ad_id"/>
        <result property="ip" column="ip"/>
        <result property="address" column="address"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectAdRegRecordVo">
        select id, ad_id, ip,address, create_by, create_time, update_by, update_time from v_ad_reg_record
    </sql>

    <select id="selectAdRegRecordList" parameterType="AdRegRecord" resultMap="AdRegRecordResult">
        <include refid="selectAdRegRecordVo"/>
        <where>
            <if test="adId != null ">and ad_id = #{adId}</if>
            <if test="ip != null  and ip != ''">and ip = #{ip}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectAdRegRecordById" parameterType="Long" resultMap="AdRegRecordResult">
        <include refid="selectAdRegRecordVo"/>
        where id = #{id}
    </select>

    <select id="selectAdRegRecordByAdId" parameterType="Long" resultType="com.ruoyi.system.domain.AdReg">
        SELECT
        SUM(CASE WHEN DATE(create_time) = CURDATE() THEN 1 ELSE 0 END) AS todayNum,
        SUM(CASE WHEN DATE(create_time) = CURDATE() - INTERVAL 1 DAY THEN 1 ELSE 0 END) AS yesterdayNum,
        COUNT(1) allNum
        FROM
        v_ad_reg_record
        where ad_id = #{adId}
    </select>

    <insert id="insertAdRegRecord" parameterType="AdRegRecord" useGeneratedKeys="true" keyProperty="id">
        insert into v_ad_reg_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="adId != null">ad_id,</if>
            <if test="ip != null">ip,</if>
            <if test="address != null">address,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="adId != null">#{adId},</if>
            <if test="ip != null">#{ip},</if>
            <if test="address != null">#{address},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateAdRegRecord" parameterType="AdRegRecord">
        update v_ad_reg_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="adId != null">ad_id = #{adId},</if>
            <if test="ip != null">ip = #{ip},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAdRegRecordById" parameterType="Long">
        delete from v_ad_reg_record where id = #{id}
    </delete>

    <delete id="deleteAdRegRecordByIds" parameterType="String">
        delete from v_ad_reg_record where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>