<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AdUseRecordMapper">

    <resultMap type="AdUseRecord" id="AdUseRecordResult">
        <result property="id" column="id"/>
        <result property="adId" column="ad_id"/>
        <result property="userId" column="user_id"/>
        <result property="ip" column="ip"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectAdUseRecordVo">
        select id, ad_id, user_id, ip, create_by, create_time, update_by, update_time from v_ad_use_record
    </sql>

    <select id="selectAdUseRecordList" parameterType="AdUseRecord" resultMap="AdUseRecordResult">
        <include refid="selectAdUseRecordVo"/>
        <where>
            <if test="adId != null ">and ad_id = #{adId}</if>
            <if test="userId != null ">and user_id = #{userId}</if>
            <if test="ip != null  and ip != ''">and ip = #{ip}</if>
        </where>
    </select>

    <select id="selectAdUseRecordById" parameterType="Long" resultMap="AdUseRecordResult">
        <include refid="selectAdUseRecordVo"/>
        where id = #{id}
    </select>

    <select id="selectAdUseRecordByIdAndUserId" resultMap="AdUseRecordResult">
        <include refid="selectAdUseRecordVo"/>
        where id = #{adId}
        <if test="userId != null and userId !=''">
            and (user_id = #{userId} or ip = #{ip})
        </if>
        and ip = #{ip}
        and DATE_FORMAT(create_time,'yyyy-MM-dd') = DATE_FORMAT(now(),'yyyy-MM-dd')
    </select>

    <insert id="insertAdUseRecord" parameterType="AdUseRecord" useGeneratedKeys="true" keyProperty="id">
        insert into v_ad_use_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="adId != null">ad_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="ip != null">ip,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="adId != null">#{adId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="ip != null">#{ip},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateAdUseRecord" parameterType="AdUseRecord">
        update v_ad_use_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="adId != null">ad_id = #{adId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="ip != null">ip = #{ip},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAdUseRecordById" parameterType="Long">
        delete from v_ad_use_record where id = #{id}
    </delete>

    <delete id="deleteAdUseRecordByIds" parameterType="String">
        delete from v_ad_use_record where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>