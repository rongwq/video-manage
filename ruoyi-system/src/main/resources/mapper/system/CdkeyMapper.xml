<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.CdkeyMapper">
    
    <resultMap type="Cdkey" id="CdkeyResult">
        <result property="cdkeyId"    column="cdkey_id"    />
        <result property="cdkeyCode"    column="cdkey_code"    />
        <result property="userId"    column="user_id"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectCdkeyVo">
        select cdkey_id, cdkey_code, user_id, status, create_by, create_time, update_by, update_time from v_cdkey
    </sql>

    <select id="selectCdkeyList" parameterType="Cdkey" resultMap="CdkeyResult">
        <include refid="selectCdkeyVo"/>
        <where>  
            <if test="cdkeyCode != null  and cdkeyCode != ''"> and cdkey_code = #{cdkeyCode}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by cdkey_id desc
    </select>
    
    <select id="selectCdkeyByCdkeyId" parameterType="Long" resultMap="CdkeyResult">
        <include refid="selectCdkeyVo"/>
        where cdkey_id = #{cdkeyId}
    </select>

    <select id="selectCdkeyByCdkeyCode" parameterType="String" resultMap="CdkeyResult">
        <include refid="selectCdkeyVo"/>
        where cdkey_code = #{cdkeyCode}
    </select>

    <insert id="insertCdkey" parameterType="Cdkey" useGeneratedKeys="true" keyProperty="cdkeyId">
        insert into v_cdkey
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cdkeyCode != null and cdkeyCode != ''">cdkey_code,</if>
            <if test="userId != null">user_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cdkeyCode != null and cdkeyCode != ''">#{cdkeyCode},</if>
            <if test="userId != null">#{userId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateCdkey" parameterType="Cdkey">
        update v_cdkey
        <trim prefix="SET" suffixOverrides=",">
            <if test="cdkeyCode != null and cdkeyCode != ''">cdkey_code = #{cdkeyCode},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where cdkey_id = #{cdkeyId}
    </update>

    <delete id="deleteCdkeyByCdkeyId" parameterType="Long">
        delete from v_cdkey where cdkey_id = #{cdkeyId}
    </delete>

    <delete id="deleteCdkeyByCdkeyIds" parameterType="String">
        delete from v_cdkey where cdkey_id in 
        <foreach item="cdkeyId" collection="array" open="(" separator="," close=")">
            #{cdkeyId}
        </foreach>
    </delete>
</mapper>