<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.RegisterActivityMapper">
    <resultMap type="com.ruoyi.system.domain.RegisterActivity" id="RegisterActivityResult">
        <id property="id" column="id" />
        <result property="activityName" column="activity_name" />
        <result property="status" column="status" />
        <result property="expireTime" column="expire_time" />
        <result property="integral" column="integral" />
        <result property="description" column="description" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectRegisterActivityVo">
        select id, activity_name, status, expire_time, integral, description, create_time, update_time 
        from register_activity
    </sql>

    <select id="selectRegisterActivityById" parameterType="Long" resultMap="RegisterActivityResult">
        <include refid="selectRegisterActivityVo" />
        where id = #{id}
    </select>

    <select id="selectRegisterActivityList" parameterType="com.ruoyi.system.domain.RegisterActivity" resultMap="RegisterActivityResult">
        <include refid="selectRegisterActivityVo" />
        <where>
            <if test="activityName != null and activityName != ''">
                and activity_name like concat('%', #{activityName}, '%')
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="expireTime != null">
                and expire_time = #{expireTime}
            </if>
            <if test="description != null and description != ''">
                and description like concat('%', #{description}, '%')
            </if>
        </where>
    </select>

    <insert id="insertRegisterActivity" parameterType="com.ruoyi.system.domain.RegisterActivity" useGeneratedKeys="true" keyProperty="id">
        insert into register_activity
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="activityName != null and activityName != ''">activity_name,</if>
            <if test="status != null">status,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="integral != null">integral,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="activityName != null and activityName != ''">#{activityName},</if>
            <if test="status != null">#{status},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="integral != null">#{integral},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateRegisterActivity" parameterType="com.ruoyi.system.domain.RegisterActivity">
        update register_activity
        <set>
            <if test="activityName != null and activityName != ''">activity_name = #{activityName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="integral != null">integral = #{integral},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteRegisterActivityById" parameterType="Long">
        delete from register_activity where id = #{id}
    </delete>

    <delete id="deleteRegisterActivityByIds" parameterType="Long[]">
        delete from register_activity where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectCurrentActivity" resultMap="RegisterActivityResult">
        <include refid="selectRegisterActivityVo" />
        where status = 1 and expire_time >= now()
        order by create_time desc
        limit 1
    </select>
</mapper>
