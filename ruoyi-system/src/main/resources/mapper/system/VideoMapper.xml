<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.VideoMapper">
    
    <resultMap type="Video" id="VideoResult">
        <result property="id"    column="id"    />
        <result property="img"    column="img"    />
        <result property="url"    column="url"    />
        <result property="title"    column="title"    />
        <result property="category"    column="category"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="type"    column="type"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="likeNum"    column="like_num"    />
        <result property="playNum"    column="play_num"    />
        <result property="money"    column="money"    />
    </resultMap>

    <sql id="selectVideoVo">
        select id, img, url, title, category, status, remark, type, create_by, create_time, update_by, update_time, like_num, play_num, money from v_video
    </sql>

    <select id="selectVideoList" parameterType="Video" resultMap="VideoResult">
        <include refid="selectVideoVo"/>
        <where>  
            <if test="url != null  and url != ''"> and url = #{url}</if>
            <if test="title != null  and title != ''"> and title like concat('%',#{title},'%')</if>
            <if test="category != null  and category != ''"> and (category = #{category} or category like concat(#{category},',%') or category like concat('%,',#{category}) or category like concat('%,',#{category},',%'))</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
        </where>
        order by create_time desc
    </select>

    <select id="selectRecommendList" parameterType="Video" resultMap="VideoResult">
        <include refid="selectVideoVo"/>
        <where>
            <if test="category != null  and category != ''"> and (category = #{category} or category like concat(#{category},',%') or category like concat('%,',#{category}) or category like concat('%,',#{category},',%'))</if>
            <if test="id != null"> and id != #{id}</if>
        </where>
        order by play_num desc
        limit 6
    </select>
    
    <select id="selectVideoById" parameterType="Long" resultMap="VideoResult">
        <include refid="selectVideoVo"/>
        where id = #{id}
    </select>

    <insert id="insertVideo" parameterType="Video" useGeneratedKeys="true" keyProperty="id">
        insert into v_video
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="img != null">img,</if>
            <if test="url != null">url,</if>
            <if test="title != null">title,</if>
            <if test="category != null">category,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="type != null">type,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="money != null">money,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="img != null">#{img},</if>
            <if test="url != null">#{url},</if>
            <if test="title != null">#{title},</if>
            <if test="category != null">#{category},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="type != null">#{type},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="money != null">#{money},</if>
         </trim>
    </insert>

    <update id="updateVideo" parameterType="Video">
        update v_video
        <trim prefix="SET" suffixOverrides=",">
            <if test="img != null">img = #{img},</if>
            <if test="url != null">url = #{url},</if>
            <if test="title != null">title = #{title},</if>
            <if test="category != null">category = #{category},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="type != null">type = #{type},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="money != null">money = #{money},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteVideoById" parameterType="Long">
        delete from v_video where id = #{id}
    </delete>

    <delete id="deleteVideoByIds" parameterType="String">
        delete from v_video where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectVideoListByCategoryId" parameterType="Long" resultMap="VideoResult">
        <include refid="selectVideoVo"/>
        where category = #{id} or category like concat(#{id},',%') or category like concat('%,',#{id}) or category like concat('%,',#{id},',%')
        order by create_time desc
        limit 6
    </select>

    <update id="updateLikeNum">
        update v_video set like_num = like_num + 1
        where id = #{id}
    </update>

    <update id="cancelLikeNum">
        update v_video set like_num = like_num - 1
        where id = #{id}
    </update>

    <update id="updatePlayNum">
        update v_video set play_num = play_num + 1
        where id = #{id}
    </update>
</mapper>