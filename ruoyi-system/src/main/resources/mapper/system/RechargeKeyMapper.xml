<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.RechargeKeyMapper">
    
    <resultMap type="RechargeKey" id="RechargeKeyResult">
        <result property="id"    column="id"    />
        <result property="code"    column="code"    />
        <result property="money"    column="money"    />
        <result property="userId"    column="user_id"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectRechargeKeyVo">
        select id, code, money, user_id, status, create_by, create_time, update_by, update_time from v_recharge_key
    </sql>

    <select id="selectRechargeKeyList" parameterType="RechargeKey" resultMap="RechargeKeyResult">
        <include refid="selectRechargeKeyVo"/>
        <where>  
            <if test="code != null  and code != ''"> and code = #{code}</if>
            <if test="money != null "> and money = #{money}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectRechargeKeyById" parameterType="Long" resultMap="RechargeKeyResult">
        <include refid="selectRechargeKeyVo"/>
        where id = #{id}
    </select>

    <insert id="insertRechargeKey" parameterType="RechargeKey" useGeneratedKeys="true" keyProperty="id">
        insert into v_recharge_key
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">code,</if>
            <if test="money != null">money,</if>
            <if test="userId != null">user_id,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="code != null and code != ''">#{code},</if>
            <if test="money != null">#{money},</if>
            <if test="userId != null">#{userId},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateRechargeKey" parameterType="RechargeKey">
        update v_recharge_key
        <trim prefix="SET" suffixOverrides=",">
            <if test="code != null and code != ''">code = #{code},</if>
            <if test="money != null">money = #{money},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteRechargeKeyById" parameterType="Long">
        delete from v_recharge_key where id = #{id}
    </delete>

    <delete id="deleteRechargeKeyByIds" parameterType="String">
        delete from v_recharge_key where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>