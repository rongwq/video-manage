<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AdRegMapper">
    
    <resultMap type="AdReg" id="AdRegResult">
        <result property="id"    column="id"    />
        <result property="url"    column="url"    />
        <result property="title"    column="title"    />
        <result property="orderNum"    column="order_num"    />
        <result property="remark"    column="remark"    />
        <result property="type"    column="type"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAdRegVo">
        select id, url, title, order_num, remark, type, create_by, create_time, update_by, update_time from v_ad_reg
    </sql>

    <select id="selectAdRegList" parameterType="AdReg" resultMap="AdRegResult">
        <include refid="selectAdRegVo"/>
        <where>  
            <if test="url != null  and url != ''"> and url = #{url}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="type != null  and type != ''"> and type = #{type}</if>
        </where>
        order by order_num asc
    </select>

    <select id="selectAdRegByOrderNum" resultMap="AdRegResult">
        <include refid="selectAdRegVo"/>
        <where>
         <if test="orderNum != null "> and order_num > #{orderNum}</if>
        </where>
        order by order_num asc
        limit 1
    </select>

    <select id="selectAdRegById" parameterType="Long" resultMap="AdRegResult">
        <include refid="selectAdRegVo"/>
        where id = #{id}
    </select>

    <insert id="insertAdReg" parameterType="AdReg" useGeneratedKeys="true" keyProperty="id">
        insert into v_ad_reg
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="url != null">url,</if>
            <if test="title != null">title,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="remark != null">remark,</if>
            <if test="type != null">type,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="url != null">#{url},</if>
            <if test="title != null">#{title},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="remark != null">#{remark},</if>
            <if test="type != null">#{type},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAdReg" parameterType="AdReg">
        update v_ad_reg
        <trim prefix="SET" suffixOverrides=",">
            <if test="url != null">url = #{url},</if>
            <if test="title != null">title = #{title},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="type != null">type = #{type},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAdRegById" parameterType="Long">
        delete from v_ad_reg where id = #{id}
    </delete>

    <delete id="deleteAdRegByIds" parameterType="String">
        delete from v_ad_reg where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>