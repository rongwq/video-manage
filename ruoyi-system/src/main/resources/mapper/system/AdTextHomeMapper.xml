<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AdTextHomeMapper">
    
    <resultMap type="AdTextHome" id="AdTextHomeResult">
        <result property="id"    column="id"    />
        <result property="content"    column="content"    />
        <result property="orderNum"    column="order_num"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAdTextHomeVo">
        select id, content, order_num, status, create_by, create_time, update_by, update_time from v_ad_text_home
    </sql>

    <select id="selectAdTextHomeList" parameterType="AdTextHome" resultMap="AdTextHomeResult">
        <include refid="selectAdTextHomeVo"/>
        <where>  
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="orderNum != null "> and order_num = #{orderNum}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
        order by order_num asc
    </select>
    
    <select id="selectAdTextHomeById" parameterType="Long" resultMap="AdTextHomeResult">
        <include refid="selectAdTextHomeVo"/>
        where id = #{id}
    </select>

    <insert id="insertAdTextHome" parameterType="AdTextHome" useGeneratedKeys="true" keyProperty="id">
        insert into v_ad_text_home
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="content != null">content,</if>
            <if test="orderNum != null">order_num,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="content != null">#{content},</if>
            <if test="orderNum != null">#{orderNum},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAdTextHome" parameterType="AdTextHome">
        update v_ad_text_home
        <trim prefix="SET" suffixOverrides=",">
            <if test="content != null">content = #{content},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAdTextHomeById" parameterType="Long">
        delete from v_ad_text_home where id = #{id}
    </delete>

    <delete id="deleteAdTextHomeByIds" parameterType="String">
        delete from v_ad_text_home where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>