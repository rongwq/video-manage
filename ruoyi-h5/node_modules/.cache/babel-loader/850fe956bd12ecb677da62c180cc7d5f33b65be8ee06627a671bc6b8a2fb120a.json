{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'Login',\n  data() {\n    return {\n      form: {\n        username: 'admin',\n        password: 'admin123'\n      },\n      loading: false\n    };\n  },\n  methods: {\n    /**\n     * 提交登录\n     */\n    onSubmit() {\n      this.loading = true;\n      this.$store.dispatch('Login', this.form).then(() => {\n        this.$toast.success('登录成功');\n        const redirect = this.$route.query.redirect || '/';\n        this.$router.push(redirect);\n      }).catch(() => {\n        this.loading = false;\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","form","username","password","loading","methods","onSubmit","$store","dispatch","then","$toast","success","redirect","$route","query","$router","push","catch"],"sources":["src/views/login/index.vue"],"sourcesContent":["<template>\n  <div class=\"login-page\">\n    <div class=\"login-header\">\n      <h1 class=\"title\">RuoYi H5</h1>\n      <p class=\"subtitle\">视频管理系统</p>\n    </div>\n\n    <van-form @submit=\"onSubmit\" class=\"login-form\">\n      <van-cell-group inset>\n        <van-field\n          v-model=\"form.username\"\n          name=\"username\"\n          label=\"用户名\"\n          placeholder=\"请输入用户名\"\n          :rules=\"[{ required: true, message: '请填写用户名' }]\"\n          left-icon=\"user-o\"\n        />\n        <van-field\n          v-model=\"form.password\"\n          type=\"password\"\n          name=\"password\"\n          label=\"密码\"\n          placeholder=\"请输入密码\"\n          :rules=\"[{ required: true, message: '请填写密码' }]\"\n          left-icon=\"lock\"\n        />\n      </van-cell-group>\n\n      <div class=\"login-btn-wrapper\">\n        <van-button\n          round\n          block\n          type=\"primary\"\n          native-type=\"submit\"\n          :loading=\"loading\"\n          loading-text=\"登录中...\"\n        >\n          登录\n        </van-button>\n      </div>\n    </van-form>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'Login',\n  data() {\n    return {\n      form: {\n        username: 'admin',\n        password: 'admin123'\n      },\n      loading: false\n    }\n  },\n  methods: {\n    /**\n     * 提交登录\n     */\n    onSubmit() {\n      this.loading = true\n      this.$store\n        .dispatch('Login', this.form)\n        .then(() => {\n          this.$toast.success('登录成功')\n          const redirect = this.$route.query.redirect || '/'\n          this.$router.push(redirect)\n        })\n        .catch(() => {\n          this.loading = false\n        })\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.login-page {\n  min-height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  padding: 20px;\n}\n\n.login-header {\n  text-align: center;\n  margin-bottom: 40px;\n\n  .title {\n    font-size: 36px;\n    color: #fff;\n    margin: 0 0 10px 0;\n    font-weight: 600;\n  }\n\n  .subtitle {\n    font-size: 16px;\n    color: rgba(255, 255, 255, 0.8);\n    margin: 0;\n  }\n}\n\n.login-form {\n  .login-btn-wrapper {\n    margin: 24px 16px 0;\n  }\n}\n</style>\n"],"mappings":";AA6CA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,IAAA;QACAC,QAAA;QACAC,QAAA;MACA;MACAC,OAAA;IACA;EACA;EACAC,OAAA;IACA;AACA;AACA;IACAC,SAAA;MACA,KAAAF,OAAA;MACA,KAAAG,MAAA,CACAC,QAAA,eAAAP,IAAA,EACAQ,IAAA;QACA,KAAAC,MAAA,CAAAC,OAAA;QACA,MAAAC,QAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAF,QAAA;QACA,KAAAG,OAAA,CAAAC,IAAA,CAAAJ,QAAA;MACA,GACAK,KAAA;QACA,KAAAb,OAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}