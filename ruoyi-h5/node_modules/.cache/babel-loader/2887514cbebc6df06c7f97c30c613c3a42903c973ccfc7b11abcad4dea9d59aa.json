{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { listVideo } from '@/api/video';\nimport { formatVideoTime } from '@/utils/index';\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      videoList: [],\n      loading: false,\n      finished: false,\n      refreshing: false,\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10\n      },\n      defaultCover: 'https://img.yzcdn.cn/vant/cat.jpeg'\n    };\n  },\n  methods: {\n    formatVideoTime,\n    /**\n     * 加载视频列表\n     */\n    onLoad() {\n      listVideo(this.queryParams).then(response => {\n        const rows = response.rows || [];\n        const total = response.total || 0;\n        if (this.refreshing) {\n          this.videoList = rows;\n          this.refreshing = false;\n        } else {\n          this.videoList.push(...rows);\n        }\n        this.loading = false;\n        if (this.videoList.length >= total) {\n          this.finished = true;\n        } else {\n          this.queryParams.pageNum++;\n        }\n      }).catch(() => {\n        this.loading = false;\n        this.finished = true;\n      });\n    },\n    /**\n     * 下拉刷新\n     */\n    onRefresh() {\n      this.finished = false;\n      this.queryParams.pageNum = 1;\n      this.onLoad();\n    },\n    /**\n     * 跳转到播放页\n     */\n    goToPlay(id) {\n      this.$router.push(`/video/play/${id}`);\n    }\n  }\n};","map":{"version":3,"names":["listVideo","formatVideoTime","name","data","videoList","loading","finished","refreshing","queryParams","pageNum","pageSize","defaultCover","methods","onLoad","then","response","rows","total","push","length","catch","onRefresh","goToPlay","id","$router"],"sources":["src/views/home/index.vue"],"sourcesContent":["<template>\n  <div class=\"home-page\">\n    <!-- 导航栏 -->\n    <van-nav-bar title=\"视频列表\" fixed placeholder :border=\"false\" />\n\n    <!-- 视频列表 -->\n    <van-pull-refresh v-model=\"refreshing\" @refresh=\"onRefresh\">\n      <van-list\n        v-model=\"loading\"\n        :finished=\"finished\"\n        finished-text=\"没有更多了\"\n        @load=\"onLoad\"\n        class=\"video-list\"\n      >\n        <div\n          v-for=\"video in videoList\"\n          :key=\"video.id\"\n          class=\"video-card\"\n          @click=\"goToPlay(video.id)\"\n        >\n          <div class=\"video-cover\">\n            <van-image\n              :src=\"video.img || defaultCover\"\n              fit=\"cover\"\n              width=\"100%\"\n              height=\"100%\"\n              lazy-load\n            />\n            <div class=\"video-duration\" v-if=\"video.duration\">\n              {{ formatVideoTime(video.duration) }}\n            </div>\n            <div class=\"play-icon\">\n              <van-icon name=\"play-circle-o\" size=\"40\" />\n            </div>\n          </div>\n          <div class=\"video-info\">\n            <h3 class=\"video-title\">{{ video.title }}</h3>\n            <p class=\"video-desc\" v-if=\"video.remark\">{{ video.remark }}</p>\n            <div class=\"video-stats\">\n              <span class=\"stats-item\">\n                <van-icon name=\"play-circle-o\" />\n                {{ video.playNum || 0 }}\n              </span>\n              <span class=\"stats-item\" v-if=\"video.likeNum\">\n                <van-icon name=\"good-job-o\" />\n                {{ video.likeNum }}\n              </span>\n            </div>\n          </div>\n        </div>\n      </van-list>\n    </van-pull-refresh>\n  </div>\n</template>\n\n<script>\nimport { listVideo } from '@/api/video'\nimport { formatVideoTime } from '@/utils/index'\n\nexport default {\n  name: 'Home',\n  data() {\n    return {\n      videoList: [],\n      loading: false,\n      finished: false,\n      refreshing: false,\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10\n      },\n      defaultCover: 'https://img.yzcdn.cn/vant/cat.jpeg'\n    }\n  },\n  methods: {\n    formatVideoTime,\n\n    /**\n     * 加载视频列表\n     */\n    onLoad() {\n      listVideo(this.queryParams).then(response => {\n        const rows = response.rows || []\n        const total = response.total || 0\n\n        if (this.refreshing) {\n          this.videoList = rows\n          this.refreshing = false\n        } else {\n          this.videoList.push(...rows)\n        }\n\n        this.loading = false\n\n        if (this.videoList.length >= total) {\n          this.finished = true\n        } else {\n          this.queryParams.pageNum++\n        }\n      }).catch(() => {\n        this.loading = false\n        this.finished = true\n      })\n    },\n\n    /**\n     * 下拉刷新\n     */\n    onRefresh() {\n      this.finished = false\n      this.queryParams.pageNum = 1\n      this.onLoad()\n    },\n\n    /**\n     * 跳转到播放页\n     */\n    goToPlay(id) {\n      this.$router.push(`/video/play/${id}`)\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.home-page {\n  min-height: 100vh;\n  background-color: #f5f5f5;\n}\n\n.video-list {\n  padding: 12px;\n}\n\n.video-card {\n  background-color: #fff;\n  border-radius: 8px;\n  overflow: hidden;\n  margin-bottom: 12px;\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);\n\n  &:active {\n    opacity: 0.9;\n  }\n}\n\n.video-cover {\n  position: relative;\n  width: 100%;\n  padding-top: 56.25%; // 16:9\n  background-color: #000;\n\n  .van-image {\n    position: absolute;\n    top: 0;\n    left: 0;\n  }\n\n  .video-duration {\n    position: absolute;\n    right: 8px;\n    bottom: 8px;\n    padding: 2px 6px;\n    background-color: rgba(0, 0, 0, 0.7);\n    color: #fff;\n    font-size: 12px;\n    border-radius: 4px;\n  }\n\n  .play-icon {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    color: rgba(255, 255, 255, 0.9);\n  }\n}\n\n.video-info {\n  padding: 12px;\n\n  .video-title {\n    margin: 0 0 8px 0;\n    font-size: 16px;\n    font-weight: 600;\n    color: #323233;\n    line-height: 1.4;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n  }\n\n  .video-desc {\n    margin: 0 0 8px 0;\n    font-size: 13px;\n    color: #666;\n    line-height: 1.5;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    display: -webkit-box;\n    -webkit-line-clamp: 2;\n    -webkit-box-orient: vertical;\n  }\n\n  .video-stats {\n    display: flex;\n    gap: 16px;\n\n    .stats-item {\n      display: flex;\n      align-items: center;\n      gap: 4px;\n      font-size: 12px;\n      color: #969799;\n\n      .van-icon {\n        font-size: 14px;\n      }\n    }\n  }\n}\n</style>\n"],"mappings":";AAwDA,SAAAA,SAAA;AACA,SAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,SAAA;MACAC,OAAA;MACAC,QAAA;MACAC,UAAA;MACAC,WAAA;QACAC,OAAA;QACAC,QAAA;MACA;MACAC,YAAA;IACA;EACA;EACAC,OAAA;IACAX,eAAA;IAEA;AACA;AACA;IACAY,OAAA;MACAb,SAAA,MAAAQ,WAAA,EAAAM,IAAA,CAAAC,QAAA;QACA,MAAAC,IAAA,GAAAD,QAAA,CAAAC,IAAA;QACA,MAAAC,KAAA,GAAAF,QAAA,CAAAE,KAAA;QAEA,SAAAV,UAAA;UACA,KAAAH,SAAA,GAAAY,IAAA;UACA,KAAAT,UAAA;QACA;UACA,KAAAH,SAAA,CAAAc,IAAA,IAAAF,IAAA;QACA;QAEA,KAAAX,OAAA;QAEA,SAAAD,SAAA,CAAAe,MAAA,IAAAF,KAAA;UACA,KAAAX,QAAA;QACA;UACA,KAAAE,WAAA,CAAAC,OAAA;QACA;MACA,GAAAW,KAAA;QACA,KAAAf,OAAA;QACA,KAAAC,QAAA;MACA;IACA;IAEA;AACA;AACA;IACAe,UAAA;MACA,KAAAf,QAAA;MACA,KAAAE,WAAA,CAAAC,OAAA;MACA,KAAAI,MAAA;IACA;IAEA;AACA;AACA;IACAS,SAAAC,EAAA;MACA,KAAAC,OAAA,CAAAN,IAAA,gBAAAK,EAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}